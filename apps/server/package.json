{
  "name": "@cuecommx/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "@cuecommx/protocol": "0.1.0",
    "better-sqlite3": "^11.10.0",
    "bonjour-service": "^1.3.0",
    "fastify": "^5.3.2",
    "mediasoup": "^3.18.1",
    "ws": "^8.18.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3"
  }
}
