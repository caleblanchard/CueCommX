{
  "name": "cuecommx",
  "version": "0.1.0",
  "private": true,
  "description": "CueCommX local-network intercom monorepo",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:e2e:mobile:android": "npm run test:e2e:android --workspace @cuecommx/mobile",
    "test:e2e:mobile:ios": "npm run test:e2e:ios --workspace @cuecommx/mobile",
    "test:e2e:web": "playwright test",
    "test:e2e:web:install": "playwright install chromium",
    "test:watch": "turbo run test:watch --parallel",
    "typecheck": "turbo run typecheck",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0"
  }
}
