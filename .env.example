# CueCommX server environment variables
# Copy this file to .env and edit values, then reference it in docker-compose.yml

# ─── Required ────────────────────────────────────────────────────────────────

# The LAN IP address of the Linux host running CueCommX.
# WebRTC clients use this address to reach the media server.
# Run `ip route get 1` on the host and look for "src <IP>" to find your LAN IP.
CUECOMMX_ANNOUNCED_IP=192.168.1.50

# ─── Optional (shown with defaults) ─────────────────────────────────────────

# Human-readable name shown to clients on the connect screen
CUECOMMX_SERVER_NAME=CueCommX

# HTTP port the server listens on
CUECOMMX_PORT=3000

# UDP port range reserved for WebRTC media streams.
# Must be open in the host firewall (see DEPLOY.md).
CUECOMMX_RTC_MIN_PORT=40000
CUECOMMX_RTC_MAX_PORT=41000

# Maximum concurrent users / channels
CUECOMMX_MAX_USERS=30
CUECOMMX_MAX_CHANNELS=16

# Log level: debug | info | warn | error
CUECOMMX_LOG_LEVEL=info

# ─── HTTPS (optional) ────────────────────────────────────────────────────────
# Both HTTP and HTTPS run simultaneously when TLS is configured.
# Mount the certificate files into the container and set these paths.
# CUECOMMX_HTTPS_PORT=3443
# CUECOMMX_TLS_CERT_FILE=/etc/cuecommx/certs/server.crt
# CUECOMMX_TLS_KEY_FILE=/etc/cuecommx/certs/server.key
